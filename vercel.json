      "permanent": false
    },
    {
      "source": "/twitter",
      "destination": "/?utm_source=twitter&utm_medium=social&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/youtube",
      "destination": "/?utm_source=youtube&utm_medium=social&utm_campaign=bio",
      "permanent": false
    }
  ]
