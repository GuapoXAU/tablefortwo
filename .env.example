# ════════════════════════════════════════════════
# Table for Two — Environment Variables
# ════════════════════════════════════════════════
# Copy this file to .env.local for local development.
# On Vercel, set these in Settings → Environment Variables.

# Supabase (public — safe to expose on client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Supabase (private — NEVER expose on client, server-side only)
# Used for admin operations, migrations, and server functions
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Formspree (public — form submission endpoint)
NEXT_PUBLIC_FORMSPREE_ID=xreodnbr

# Admin dashboard password
ADMIN_PASSWORD=t4t-admin-2026

# App settings
NEXT_PUBLIC_APP_URL=https://tablefortwo.uk
NEXT_PUBLIC_SITE_NAME=Table for Two
